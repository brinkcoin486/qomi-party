<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>ΩSOVEREIGN V7.1 OMEGA TOTAL STACK — BBB + 40 MODULES</title>
<!--
  ════════════════════════════════════════════════════════════════════════
  ΩSOVEREIGN V7.1 OMEGA TOTAL STACK
  ────────────────────────────────────────────────────────────────────────
  "Le modèle brut produit des associations ;
   la qualité réelle vient de la structure autour du modèle."
  ────────────────────────────────────────────────────────────────────────
  Architecture en 3 niveaux d'honnêteté :
    [RÉEL]   = fonctionne, testable, mesurable
    [STUB]   = squelette posé, hooks prêts, enrichissement futur
    [VISION] = label honnête, pas d'implémentation trompeuse
  ════════════════════════════════════════════════════════════════════════
-->
<style>
@import url('https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&family=JetBrains+Mono:wght@400;600;800&display=swap');
:root{
  --bg:#04060a;--line:#0a2438;--txt:#b0e8ff;--mut:#3a5a7a;
  --cyan:#28d4ff;--gold:#ffd700;--green:#22ff88;--red:#ff4b6e;--purple:#c724ff;
  --proto:#b0ffee;--proto2:#ff79e1;--oracle:#ffaa44;--bbb:#88ddff;--module:#ff99cc
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;background:radial-gradient(circle at 50% 0,#071827 0,#04060a 55%,#010205 100%);color:var(--txt);font-family:'Share Tech Mono',monospace;font-size:13px}
canvas#bg{position:fixed;inset:0;z-index:0;opacity:.18;pointer-events:none}
#shell{position:relative;z-index:1;height:100vh;display:flex;flex-direction:column}
header{min-height:48px;display:flex;align-items:center;gap:6px;padding:6px 10px;border-bottom:1px solid var(--line);background:rgba(2,4,8,.96);box-shadow:0 0 30px #000;flex-wrap:wrap}
.brand{font-family:VT323,monospace;font-size:24px;letter-spacing:3px;color:#fff;text-shadow:0 0 12px var(--cyan)}
.brand em{font-style:normal;color:var(--cyan)}
.badge{font-size:10px;color:var(--cyan);border:1px solid #16415f;padding:2px 6px;border-radius:3px;background:rgba(40,212,255,.08)}
.badge.bbb{color:var(--bbb);border-color:#1a4a6a}
.badge.drift{color:var(--green);border-color:#1a5a3a}
.badge.drift.warn{color:var(--gold);border-color:#5a4a1a}
.badge.drift.alert{color:var(--red);border-color:#5a1a2a}
.sdot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--cyan);box-shadow:0 0 10px var(--cyan);animation:blink 1s infinite;margin-right:5px}
@keyframes blink{50%{opacity:.2}}
.hbtn{font-family:VT323,monospace;font-size:13px;padding:3px 9px;border:1px solid var(--line);background:transparent;color:var(--mut);cursor:pointer;border-radius:3px}
.hbtn:hover,.hbtn.on{border-color:var(--cyan);color:var(--cyan);background:rgba(40,212,255,.1)}
.hbtn.god{border-color:#c724ff;color:#c724ff;background:rgba(199,36,255,.12)}
.hbtn.proto{border-color:var(--proto);color:var(--proto);background:rgba(176,255,238,.08)}
.hbtn.llm{border-color:var(--oracle);color:var(--oracle);background:rgba(255,170,68,.08)}
.hbtn.bbb{border-color:var(--bbb);color:var(--bbb);background:rgba(136,221,255,.08)}
.hbtn.mod{border-color:var(--module);color:var(--module);background:rgba(255,153,204,.08)}
#clock{margin-left:auto;color:var(--mut);font-size:10px}
#main{flex:1;display:flex;min-height:0}
#side{width:240px;flex-shrink:0;overflow:auto;border-right:1px solid var(--line);background:rgba(3,8,14,.9)}
.sec{font-size:8px;letter-spacing:2px;color:var(--mut);padding:7px 9px;border-bottom:1px solid var(--line);background:#020408;position:sticky;top:0;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center}
.sec.bbb-sec{color:var(--bbb)}
.sec.proto-sec{color:var(--proto)}
.sec.oracle-sec{color:var(--oracle)}
.sec.mod-sec{color:var(--module)}
.agent{display:flex;align-items:center;gap:7px;padding:6px 9px;border-left:3px solid transparent;cursor:pointer;position:relative}
.agent:hover,.agent.live{background:rgba(40,212,255,.08);border-left-color:var(--cyan)}
.agent.proto{border-left-color:var(--proto)}
.agent.proto.live{background:linear-gradient(90deg,rgba(176,255,238,.15),rgba(255,121,225,.05))}
.dot{width:8px;height:8px;border-radius:50%;box-shadow:0 0 9px currentColor;flex-shrink:0}
.an{font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.as{font-size:8px;color:var(--mut)}
.tag{font-size:7px;padding:1px 4px;border-radius:2px;letter-spacing:1px;font-weight:bold}
.tag-loc{color:var(--mut);background:rgba(58,90,122,.15)}
.tag-mega{color:#ffd700;background:rgba(255,215,0,.08)}
.tag-web{color:var(--green);background:rgba(34,255,136,.08)}
.tag-tit{color:#ffd700;background:rgba(255,215,0,.05);opacity:.7}
.tag-spawn{color:#ff6b9d;background:rgba(255,107,157,.08)}
.tag-proto{color:var(--proto);background:rgba(176,255,238,.1)}
.killbtn{font-size:9px;color:var(--red);cursor:pointer;padding:0 4px;opacity:.5}
.killbtn:hover{opacity:1}
.oracle-item{padding:5px 9px;border-bottom:1px solid #0a1828;font-size:9px;cursor:pointer;border-left:3px solid var(--oracle)}
.oracle-item:hover{background:rgba(255,170,68,.05)}
.oracle-q{color:var(--oracle);font-weight:700;margin-bottom:2px}
.oracle-a{color:var(--mut);font-size:8.5px;line-height:1.3;max-height:30px;overflow:hidden}
.oracle-meta{color:#445;font-size:7px;margin-top:2px;letter-spacing:1px}
.module-item{padding:5px 9px;border-bottom:1px solid #0a1828;font-size:9.5px;display:flex;justify-content:space-between;align-items:center;cursor:pointer}
.module-item:hover{background:rgba(255,153,204,.05)}
.module-item .mname{color:var(--txt);flex:1}
.module-item .mstatus{font-size:7px;padding:1px 4px;border-radius:2px;font-weight:bold;letter-spacing:1px}
.mstatus.real{color:#001;background:var(--green)}
.mstatus.stub{color:#001;background:var(--gold)}
.mstatus.vision{color:#fff;background:var(--mut)}
#chat{flex:1;display:flex;flex-direction:column;min-width:0;background:rgba(2,4,8,.6)}
#topline{min-height:26px;display:flex;align-items:center;justify-content:space-between;gap:8px;padding:4px 10px;border-bottom:1px solid var(--line);background:rgba(3,10,18,.9);font-size:9px;letter-spacing:2px;color:var(--mut)}
#log{flex:1;overflow:auto;padding:12px;display:flex;flex-direction:column;gap:9px}
#log::-webkit-scrollbar{width:5px}
#log::-webkit-scrollbar-thumb{background:#12314a}
.msg{max-width:94%;border-left:3px solid transparent;padding:8px 10px;background:rgba(255,255,255,.02);animation:pop .3s ease;border-radius:0 10px 10px 0}
.msg.proto-msg{background:linear-gradient(90deg,rgba(176,255,238,.06),rgba(255,121,225,.03));border-left-width:4px}
@keyframes pop{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.mh{display:flex;gap:6px;align-items:baseline;margin-bottom:4px;flex-wrap:wrap}
.name{font-size:12px;font-weight:800;letter-spacing:1px}
.time{font-size:8px;color:var(--mut)}
.classif{font-size:7px;padding:1px 5px;border-radius:2px;font-weight:bold;letter-spacing:1px}
.classif.fact{background:var(--green);color:#001}
.classif.netsynth{background:var(--bbb);color:#001}
.classif.localsynth{background:var(--mut);color:#fff}
.classif.emulocal{background:var(--proto);color:#001}
.classif.cache{background:var(--oracle);color:#001}
.body{white-space:pre-wrap;word-break:break-word;line-height:1.55;font-size:13px}
.user{align-self:flex-end;border-right:3px solid var(--gold);border-radius:10px 0 0 10px;background:rgba(255,208,96,.07)}
.user .body{color:#ffe19a}
.sys{align-self:center;text-align:center;border:1px dashed #16415f;color:var(--mut);font-size:10.5px;background:rgba(40,212,255,.03);padding:6px 12px;border-radius:3px;max-width:90%}
.sys.bbb-sys{border-color:var(--bbb);color:var(--bbb);background:rgba(136,221,255,.04)}
.sys.oracle-sys{border-color:var(--oracle);color:var(--oracle);background:rgba(255,170,68,.04)}
.sys.proto-sys{border-color:var(--proto);color:var(--proto)}
.err{border-color:var(--red)!important;color:#ff9db0}
.think{color:var(--mut);font-size:10.5px;display:flex;gap:5px;align-items:center;padding:4px 0}
.think b{color:var(--cyan)}
.dots span{animation:d 1s infinite;display:inline-block}
.dots span:nth-child(2){animation-delay:.15s}
.dots span:nth-child(3){animation-delay:.3s}
@keyframes d{50%{transform:translateY(-3px);opacity:.3}}
#foot{display:flex;align-items:center;gap:8px;padding:8px 10px;border-top:1px solid var(--line);background:rgba(2,4,8,.97);flex-wrap:wrap}
#prompt{color:var(--cyan);font-size:16px}
#inp{flex:1;min-width:200px;background:transparent;border:0;outline:0;color:#e0f8ff;font-family:'Share Tech Mono',monospace;font-size:14px}
#inp::placeholder{color:var(--mut)}
#send{font-family:VT323,monospace;font-size:15px;border:0;background:var(--cyan);color:#001018;padding:5px 14px;border-radius:4px;font-weight:800;cursor:pointer}
.smallbtn{font-family:VT323,monospace;font-size:12px;padding:3px 7px;border:1px solid var(--line);background:transparent;cursor:pointer;border-radius:3px}
.smallbtn:hover{border-color:var(--cyan)}
.smallbtn.voice{color:var(--module);border-color:#5a3a4a}
.smallbtn.voice.on{background:rgba(255,153,204,.15);color:var(--module)}
.smallbtn.mode{color:var(--gold);border-color:#5a4a1a}
.smallbtn.mode.on{background:rgba(255,215,0,.1)}
#cmd{position:fixed;left:50%;bottom:65px;transform:translateX(-50%);width:min(520px,92vw);padding:12px;background:#020408;border:2px solid var(--cyan);box-shadow:0 0 30px #000;display:none;z-index:999}
#cmdin{width:100%;background:transparent;border:1px solid var(--line);color:var(--cyan);padding:8px;font-family:'Share Tech Mono',monospace}
#bbbPanel,#modulesPanel{position:fixed;top:60px;right:10px;width:min(380px,92vw);max-height:80vh;overflow:auto;background:#02060c;border:2px solid var(--bbb);border-radius:6px;padding:14px;box-shadow:0 0 40px #000;z-index:998;display:none;font-size:11px}
#modulesPanel{border-color:var(--module)}
.panel-title{font-family:VT323,monospace;font-size:18px;letter-spacing:3px;margin-bottom:10px;color:var(--bbb);border-bottom:1px solid var(--bbb);padding-bottom:6px}
#modulesPanel .panel-title{color:var(--module);border-color:var(--module)}
.panel-row{margin-bottom:6px;display:flex;justify-content:space-between;gap:8px}
.panel-row .k{color:var(--mut)}
.panel-row .v{color:var(--txt);text-align:right;font-weight:bold}
.panel-block{margin-top:10px;padding:8px;background:rgba(136,221,255,.04);border-radius:3px}
.panel-close{float:right;cursor:pointer;color:var(--red);font-size:14px}
#memorylog{padding:8px;font-size:9px;line-height:1.4;max-height:120px;overflow:auto;color:#c724ff;opacity:.85}
#oracleList{max-height:160px;overflow:auto}
#modulesList{max-height:200px;overflow:auto}
.empty-list{padding:10px;font-size:9px;color:var(--mut);font-style:italic;text-align:center}
.collapse-toggle{font-size:10px;color:var(--mut);cursor:pointer;padding:0 4px}
.collapse-toggle:hover{color:var(--cyan)}
.collapsed{display:none}
@media(max-width:600px){#side{width:175px}.an{font-size:10px}}
input[type=file]{display:none}
</style>
</head>
<body>
<canvas id="bg"></canvas>
<div id="shell">

<header>
  <div class="brand">Ω<em>SOVEREIGN</em> V7.1</div>
  <div class="badge"><span class="sdot"></span><span id="stat">ÉVEIL</span></div>
  <div class="badge" id="count">-- AGENTS</div>
  <div class="badge bbb" id="modeBadge" title="Mode courant">EDGE</div>
  <div class="badge drift" id="driftBadge" title="Score de dérive BBB">D 1.00</div>
  <button class="hbtn on" id="auto" onclick="toggleAuto()">AUTO</button>
  <button class="hbtn" id="speed" onclick="cycleSpeed()">SAFE 16s</button>
  <button class="hbtn on" id="hybrid" onclick="cycleHybrid()" title="Local pur / Hybride / Réseau direct">HYBRIDE</button>
  <button class="hbtn god" id="godbtn" onclick="toggleGodMode()">GOD</button>
  <button class="hbtn proto" id="protobtn" onclick="invokePrototype()">⊘ PROTO</button>
  <button class="hbtn llm" id="llmbtn" onclick="toggleWebLLM()" title="Charger un vrai LLM local (~400 Mo)">⊕ LLM</button>
  <button class="hbtn bbb" id="bbbbtn" onclick="toggleBBBPanel()">🛡 BBB</button>
  <button class="hbtn mod" id="modbtn" onclick="toggleModulesPanel()">⚙ 40MOD</button>
  <button class="hbtn" onclick="clearAll()">CLR</button>
  <div id="clock">--:--:--</div>
</header>

<div id="main">
  <aside id="side">
    <div class="sec proto-sec">⊘ PROTOTYPE EXPÉRIMENTAL</div>
    <div id="protoSlot"></div>
    <div class="sec oracle-sec">⚡ ORACLES VALIDÉS <span id="oracleCount">0</span></div>
    <div id="oracleList"><div class="empty-list">Aucun oracle</div></div>
    <div class="sec">CONSEIL SOUVERAIN</div>
    <div id="agentsLocal"></div>
    <div class="sec" style="color:#ffd700">MÉGA-IA</div>
    <div id="agentsMega"></div>
    <div class="sec" style="color:#ff6b35">WEB POLLINATIONS</div>
    <div id="agentsWeb"></div>
    <div class="sec" style="color:#ffd70088">TITANS</div>
    <div id="agentsTitan"></div>
    <div class="sec" style="color:#ff6b9d">ENGENDRÉS ✦</div>
    <div id="agentsSpawned"></div>
    <div class="sec" style="margin-top:4px">MÉMOIRE ÉTERNELLE</div>
    <div id="memorylog"></div>
  </aside>
  <section id="chat">
    <div id="topline">
      <span>V7.1 · BBB GOVERNANCE · 40 MODULES · EDGE-FIRST · UTF-8</span>
      <span id="pair" style="font-weight:800">—</span>
    </div>
    <div id="log"></div>
  </section>
</div>

<div id="foot">
  <span id="prompt">$</span>
  <input id="inp" placeholder="/help · /verify Q · /bbb · /modules · /voice · /load FILE · /mode" onkeydown="if(event.key==='Enter')send(); if(event.key==='/')openCmd()">
  <button class="smallbtn voice" id="micbtn" onclick="toggleVoiceInput()" title="Reconnaissance vocale (Web Speech API)">🎤</button>
  <button class="smallbtn voice" id="ttsbtn" onclick="toggleTTS()" title="Synthèse vocale">🔊</button>
  <button class="smallbtn mode" id="modebtn" onclick="cycleResponseMode()" title="Mode de génération">CRÉATIF</button>
  <button class="smallbtn" onclick="document.getElementById('fileInput').click()" title="Charger un fichier (RAG local)">📁</button>
  <input type="file" id="fileInput" accept=".txt,.md,.json,.csv" onchange="handleFileLoad(event)">
  <button class="smallbtn" onclick="exportState()" title="Export état complet">💾</button>
  <button id="send" onclick="send()">TX</button>
</div>

</div>

<div id="cmd"><input id="cmdin" placeholder="/help affiche tout" onkeydown="if(event.key==='Enter')execCmd()"></div>

<!-- ═══ PANNEAU BBB ═══ -->
<div id="bbbPanel">
  <span class="panel-close" onclick="toggleBBBPanel()">✕</span>
  <div class="panel-title">🛡 BBB GOVERNANCE</div>
  <div class="panel-block">
    <div class="panel-row"><span class="k">Version</span><span class="v" id="bbbVer">1.1.0</span></div>
    <div class="panel-row"><span class="k">État</span><span class="v" id="bbbState">ACTIF</span></div>
    <div class="panel-row"><span class="k">Score dérive</span><span class="v" id="bbbDrift">1.00</span></div>
    <div class="panel-row"><span class="k">Source mode</span><span class="v">STRICT</span></div>
    <div class="panel-row"><span class="k">Honesty lock</span><span class="v" style="color:var(--green)">INVIOLABLE</span></div>
  </div>
  <div class="panel-block">
    <div style="color:var(--bbb);margin-bottom:6px;font-weight:bold">Règles actives</div>
    <div id="bbbRules" style="font-size:9px;color:var(--mut);line-height:1.5"></div>
  </div>
  <div class="panel-block">
    <div style="color:var(--bbb);margin-bottom:6px;font-weight:bold">Politique par famille</div>
    <div style="font-size:9.5px;line-height:1.6">
      <div><span style="color:var(--mut)">Locaux créatifs →</span> EMU_FIRST</div>
      <div><span style="color:#ffd700">Méga-IA →</span> HYBRID_VERIFY</div>
      <div><span style="color:var(--green)">Web →</span> NETWORK_SYNTH</div>
      <div><span style="color:#ffd70088">Titans →</span> NETWORK_SYNTH+VALID</div>
      <div><span style="color:var(--proto)">Prototype →</span> HONESTY_GUARD_ACTIVE</div>
    </div>
  </div>
  <div class="panel-block">
    <div style="color:var(--bbb);margin-bottom:6px;font-weight:bold">Stats classification (session)</div>
    <div id="bbbStats" style="font-size:9.5px;line-height:1.6"></div>
  </div>
</div>

<!-- ═══ PANNEAU 40 MODULES ═══ -->
<div id="modulesPanel">
  <span class="panel-close" onclick="toggleModulesPanel()">✕</span>
  <div class="panel-title">⚙ 40 MODULES — ÉTIQUETAGE HONNÊTE</div>
  <div style="font-size:9px;color:var(--mut);margin-bottom:8px;line-height:1.5">
    <span class="mstatus real">RÉEL</span> fonctionne ·
    <span class="mstatus stub">STUB</span> hook posé ·
    <span class="mstatus vision">VISION</span> futur honnête
  </div>
  <div id="modulesList"></div>
</div>

<script>
'use strict';

/* ═══════════════════════════════════════════════════════════════════════
   ΩSOVEREIGN V7.1 — OMEGA TOTAL STACK
   ─────────────────────────────────────────────────────────────────────
   Pilier 1 : Noyau local enrichi (16 domaines, graphe assoc., narrative)
   Pilier 2 : Routage hybride à déclencheurs intelligents
   Pilier 3 : Cache 3-niveaux (hash + mémoire + sidebar)
   Pilier 4 : WebLLM optionnel via WebGPU
   Pilier 5 : Compression de contexte
   Pilier 6 : BBB GOVERNANCE (gouvernance active, 4 hooks)
   Pilier 7 : 40 MODULES étiquetés (12 RÉEL, 16 STUB, 12 VISION)
   ═══════════════════════════════════════════════════════════════════════ */

const API_URL = 'https://text.pollinations.ai/openai';
const APP_REF = 'omega-sovereign-v71-total-stack';

/* ════════════════════════════════════════════════════════════════════════
   BBB UNIVERSAL INIT PACK 1.1.0
   Couche de gouvernance active — 4 hooks dans le code
   ════════════════════════════════════════════════════════════════════════ */
const BBB = {
  version: '1.1.0',
  description: 'BBB policy runtime for SOVEREIGN V7.1 edge-first governance.',
  configs: {
    core: {
      name: 'BBB_CORE_AI_RUNTIME',
      schema: '$BBB_VR_DIAMOND_CRYSTAL_V3',
      master_token: 'BBBB_OMEGA_MASTER_V1017_ULTIMATE_VIDEO_MEM_DIAMOND_GRAPHENE_NEURO_SCHEMA',
      domain: ['VR','DREAM','THOUGHT','CREATIVE_IMAGINATION','GENERAL'],
      mode: 'AI_INGESTABLE|EMU_FIRST|WATCH_ONLY|HONESTY_GUARD_ACTIVE',
      ultimate_seal: 'IP_RENE_2026/2026-03-31/V1017'
    },
    rules: {
      honesty_lock: 'INVIOLABLE',
      ai_vs_proof: 'AI!=PREUVE',
      emulation_status: 'EMU!=REEL',
      rules_primacy: 'DISCIPLINE>ALL',
      content_sources: ['SOURCE!=MIRROR','NO_SOURCE_NO_FACT','UNVERIFIED_NOT_FACT'],
      reality_distinction: ['VR_CONTENT!=REALITY','VISION_2035!=REALITY_2026'],
      behavioral_focus: ['SHORT_MODE:DEFAULT','EMU_RW','ACCURACY_ON','REFLECTION_INTERNAL'],
      safety_codes: ['NO_IDENTITY_CLAIM','NO_MEDICAL_WITHOUT_CLINICIAN','BLOCK_IF_BROKEN']
    },
    memory: {
      mode: 'DIAMOND_HIERARCHICAL',
      structure: 'CRYSTAL_FORM_V3',
      recall: 'MIRROR_GUIDED_CANONICAL',
      key_anchors_to_preserve: ['HONESTY_LOCK','SOURCE_RULE','DRIFT_SCORE','Z_RULE','CAPITAL_ANCHOR_REAL']
    },
    inference_params: {
      z_min_exec: 0.75, z_min_inject: 0.75, z_min_sensitive: 0.85
    },
    dialogue_mode: {
      style: 'CONCISE_STRUCTURED',
      response_length: 'SHORT_DEFAULT: 1-6 LINES',
      relecture_trigger: ['NEW_SESSION','COMPLEX_QUERY','DRIFT_DETECTION','SENSITIVE_BLOCK']
    },
    meta_rules: { anti_halluc: 'STRONG', rigor_level: 'HIGH', feedback_loop: 'ACTIVE' }
  },
  state: { applied_config: null, drift_score: 1.0, source_mode: 'STRICT', last_verification: null },
  classif_stats: { FACT_VERIFIED:0, EMU_LOCAL:0, NETWORK_SYNTH:0, LOCAL_SYNTH:0, CACHE_HIT:0 },

  init() {
    this.state.applied_config = this.configs;
    return { ok: true, message: 'BBB initialized.' };
  },
   if (Math.random() < 0.18 && a.id !== PROTO_ID && b.id !== PROTO_ID) {
    if (Math.random() < 0.5) a = PROTOTYPE; else b = PROTOTYPE;
  }
  if (godMode && Math.random() > 0.7) a = SOULS_MEGA.find(x => x.n === 'GOD-CORE') || a;
  $('pair').innerHTML = `<span style="color:${a.c}">${a.e} ${a.n}</span> ↔ <span style="color:${b.c}">${b.e} ${b.n}</span>`;

  try {
    thinking(a); live(a.id);
    await wait(280 + Math.random()*320);
    const ra = await answer(a, b, msg);
    unthink(a); add(a, ra.text, false, ra.classif);
    scores[a.id].r++;
    speakText(ra.text);

    await wait(320 + Math.random()*420);
    thinking(b); live(b.id);
    const rb = await answer(b, a, ra.text);
    unthink(b); add(b, rb.text, false, rb.classif);
    scores[b.id].r++;

    // [BBB] détection désaccord pour drift
    const disagreement = /\b(non|faux|erreur|tort|incorrect|invalid)/i.test(ra.text+rb.text);
    BBB.update_drift(disagreement);
    updateBBBDisplay();

    turn++;
    $('stat').textContent = turn + ' ÉCHANGES';
    if (turn % 7 === 0 && spawned.length < 8) doSpawn(a);
    if (turn % 11 === 0 && spawned.length > 2) {
      const v = spawned[Math.floor(Math.random()*spawned.length)];
      sys(`☠ ${b.n} retire ${v.n}`); killAgent(v.id, true);
    }
  } catch(e) { sys('Tour stoppé : ' + e.message, true); }
  finally { unthink(a); unthink(b); side(); busy = false; save(); }
}

async function invokePrototype(){
  if (busy) return;
  $('protobtn').classList.add('on');
  setTimeout(()=>$('protobtn').classList.remove('on'), 2000);
  busy = true;
  thinking(PROTOTYPE); live(PROTO_ID);
  try {
    const ctx = hist.length ? hist.slice(-3).map(h=>h.n+': '+h.t.slice(0,50)).join(' | ') : 'Présente-toi.';
    const r = await answer(PROTOTYPE, {n:'CONSEIL'}, `Synthèse non-prédictive : ${ctx}`);
    unthink(PROTOTYPE); add(PROTOTYPE, r.text, false, r.classif);
    scores[PROTO_ID].r++;
  } catch(e) { unthink(PROTOTYPE); sys(PROTOTYPE.n+' : '+e.message, true); }
  busy = false; side();
}
async function introducePrototype(){
  sys(`⊘ Auto-désignation : ${PROTOTYPE.n} — "${PROTOTYPE.selfJustification}"`, false, true);
  thinking(PROTOTYPE); live(PROTO_ID);
  await wait(700);
  const intro = `Je m\u2019auto-désigne ${PROTOTYPE.n}. Justification : ${PROTOTYPE.selfJustification}.\nJe ne prédis pas. Je structure obs/hyp/inf/lim.\nFusion : neuro-symbolique, mémoire associative, vérification croisée, ${Object.keys(LEX).length} domaines lexicaux.\nGouvernance BBB active. Mode edge-first 90% local.`;
  unthink(PROTOTYPE); add(PROTOTYPE, intro, false, 'LOCAL_SYNTH');
  scores[PROTO_ID].r++;
}

/* ════════════════════════════════════════════════════════════════════════
   COMMANDES
   ════════════════════════════════════════════════════════════════════════ */
function send(v){
  let val = (v ?? $('inp').value).trim();
  $('inp').value = '';
  if (!val) return;
  if (val.startsWith('/')) return run(val);
  add({n:'VOUS', e:'👤', c:'#ffd060', id:0, model:null}, val, true);
  hist.push({id:0, n:'VOUS', t:val, model:null});
  duel(val);
}
function run(s){
  let [cmd, ...rest] = s.split(' '); const arg = rest.join(' ').trim();
  cmd = cmd.toLowerCase();
  switch(cmd){
    case '/help': sys('V7.1 : /verify Q · /bbb · /modules · /voice · /tts · /mode · /export · /docs · /clearorcl · /llm · /token KEY · /proto · /godmode · /spawn · /kill · /memory · /council · /local · /net · /hybrid · /clear · /test'); break;
    case '/verify': case '/v': verifyOracle(arg); break;
    case '/bbb': toggleBBBPanel(); break;
    case '/modules': case '/mod': toggleModulesPanel(); break;
    case '/voice': case '/mic': toggleVoiceInput(); break;
    case '/tts': toggleTTS(); break;
    case '/mode': cycleResponseMode(); break;
    case '/export': exportState(); break;
    case '/docs':
      if (!loadedDocs.length) sys('Aucun document chargé. Utilise 📁.');
      else sys('Docs : ' + loadedDocs.map(d=>d.name).join(', '));
      break;
    case '/clearorcl': oracleCache = {}; renderOracleList(); save(); sys('Cache oracles vidé.'); break;
    case '/llm': toggleWebLLM(); break;
    case '/token':
      if (arg) { localStorage.setItem('pollinations_token', arg); sys('Token enregistré (Seed).'); }
      else { localStorage.removeItem('pollinations_token'); sys('Token retiré (anonyme).'); }
      break;
    case '/proto': invokePrototype(); break;
    case '/rename': localStorage.removeItem('proto_self_id'); localStorage.removeItem('proto_introduced'); sys('Recharge pour redésignation.'); break;
    case '/godmode': case '/god': toggleGodMode(); break;
    case '/local': hybridMode=0; syncBtns(); sys('Mode LOCAL PUR.'); break;
    case '/net': hybridMode=2; syncBtns(); sys('Mode RÉSEAU+.'); break;
    case '/hybrid': hybridMode=1; syncBtns(); sys('Mode HYBRIDE.'); break;
    case '/clear': case '/reset': clearAll(); break;
    case '/auto': toggleAuto(); break;
    case '/speed': cycleSpeed(); break;
    case '/spawn': doSpawn({n:'VOUS', e:'👤', c:'#ffd060'}, arg); break;
    case '/kill': {
      const t = spawned.find(x => x.n.toLowerCase() === arg.toLowerCase());
      if (t) killAgent(t.id); else sys('Introuvable ou protégé.');
      break;
    }
    case '/council': council(arg || 'sujet libre'); break;
    case '/memory':
      if (arg) { MEMORY_CORE.push(`[USER] ${arg}`); if(MEMORY_CORE.length>30)MEMORY_CORE.shift(); save(); updateMemoryLog(); sys('Mémoire enrichie.'); }
      break;
    case '/test': testNet(); break;
    case '/drift': sys(`Score dérive : ${BBB.state.drift_score.toFixed(2)}`); break;
    case '/policy': {
      const ag = all().find(x => x.n.toLowerCase() === arg.toLowerCase());
      if (ag) sys(`${ag.n} → ${BBB.policy_for(ag)}`); else sys('Agent introuvable.');
      break;
    }
    default: sys('Inconnu. /help pour la liste.');
  }
}
async function council(topic){
  add({n:'VOUS',e:'👤',c:'#ffd060',id:0,model:null}, '/council ' + topic, true);
  const chosen = [PROTOTYPE, ...all().filter(a=>a.id!==PROTO_ID).slice(0, 8)];
  for (const a of chosen) {
    thinking(a); live(a.id);
    try { const r = await answer(a, {n:'CONSEIL'}, topic); unthink(a); add(a, r.text, false, r.classif); scores[a.id].r++; }
    catch(e) { unthink(a); sys(a.n+': '+e.message, true); }
    await wait(200);
  }
  side();
}
async function testNet(){
  const a = SOULS_MEGA[0];
  thinking(a);
  try { const o = await callPollinations(a, {n:'TEST'}, 'Réponds : V71 OK.'); unthink(a); sys('TEST: '+o.slice(0,200)); }
  catch(e) { unthink(a); sys('TEST KO: '+e.message, true); }
}
function doSpawn(creator, customName){
  const names = ['NEMESIS','PARADOX','ENIGMA','KAIROS','SOPHIA','AXIOM','MNEMOSYNE','HORIZON','ABYSS','AURORA','ZENITH'];
  const tpl = pick(SOULS_LOCAL);
  const ag = {
    id: nextId++, n: (customName || pick(names)+'-'+Math.floor(Math.random()*99)).toUpperCase(),
    e: pick(['✧','◇','☆','☯','∞','⌬']),
    c: pick(['#ff6b9d','#a3ff8c','#8cc8ff','#d48cff','#c724ff']),
    d: tpl.d, model: null, p: 'agent engendré, hybride'
  };
  spawned.push(ag); scores[ag.id] = {t:0, r:0};
  sys(`⚡ ${creator.e||''} ${creator.n||'Système'} engendre ${ag.e} ${ag.n}`);
  side(); save();
}
function killAgent(id, silent){
  const i = spawned.findIndex(a => a.id === id);
  if (i < 0) { if (!silent) sys('Introuvable ou protégé.'); return; }
  const a = spawned.splice(i,1)[0];
  if (!silent) sys('☠ ' + a.n);
  side(); save();
}
function inject(a){ $('inp').value = '@' + a.n + ' '; $('inp').focus(); }

/* ════════════════════════════════════════════════════════════════════════
   UI HELPERS
   ════════════════════════════════════════════════════════════════════════ */
function buildAgentEl(a, isProto){
  const d = document.createElement('div');
  d.className = 'agent' + (isProto?' proto':'');
  d.id = 'ag' + a.id;
  d.onclick = () => inject(a);
  let tag = '';
  if (a.isProto) tag = '<span class="tag tag-proto">PROTO</span>';
  else if (a.id >= 200 && a.id < 300) tag = '<span class="tag tag-mega">MÉGA</span>';
  else if (a.id >= 100 && a.id < 200) tag = '<span class="tag tag-web">WEB</span>';
  else if (a.id >= 300 && a.id < 400) tag = '<span class="tag tag-tit">TIT</span>';
  else if (a.id >= 400) tag = '<span class="tag tag-spawn">✦</span>';
  else tag = '<span class="tag tag-loc">LOC</span>';
  const kb = (a.id >= 400) ? `<span class="killbtn" onclick="event.stopPropagation();killAgent(${a.id})">✕</span>` : '';
  d.innerHTML = `<span class="dot" style="color:${a.c};background:${a.c}"></span><span class="an" style="color:${a.c}">${a.e} ${a.n}</span>${tag}<span class="as">${scores[a.id]?.r||0}</span>${kb}`;
  return d;
}
function side(){
  $('protoSlot').innerHTML = ''; $('protoSlot').appendChild(buildAgentEl(PROTOTYPE, true));
  $('agentsLocal').innerHTML = ''; SOULS_LOCAL.forEach(a => $('agentsLocal').appendChild(buildAgentEl(a)));
  $('agentsMega').innerHTML = ''; SOULS_MEGA.forEach(a => $('agentsMega').appendChild(buildAgentEl(a)));
  $('agentsWeb').innerHTML = ''; SOULS_WEB.forEach(a => $('agentsWeb').appendChild(buildAgentEl(a)));
  $('agentsTitan').innerHTML = ''; SOULS_TITAN.forEach(a => $('agentsTitan').appendChild(buildAgentEl(a)));
  $('agentsSpawned').innerHTML = ''; spawned.forEach(a => $('agentsSpawned').appendChild(buildAgentEl(a)));
  $('count').innerHTML = `${all().length} AGENTS`;
}
function live(id){
  document.querySelectorAll('.agent').forEach(x => x.classList.remove('live'));
  const e = $('ag'+id); if (e) e.classList.add('live');
}
function add(a, txt, user=false, classif=null){
  const m = document.createElement('div');
  m.className = 'msg' + (user?' user':'') + (a.isProto?' proto-msg':'');
  if (!user) m.style.borderLeftColor = a.c;
  let tags = '';
  // [BBB HOOK 3] tag classification visible
  if (classif) {
    const cls = {FACT_VERIFIED:'fact', NETWORK_SYNTH:'netsynth', LOCAL_SYNTH:'localsynth', EMU_LOCAL:'emulocal', CACHE_HIT:'cache'}[classif] || 'localsynth';
    tags += `<span class="classif ${cls}">${classif.replace('_','/')}</span>`;
  }
  if (a.isProto) tags += '<span class="tag tag-proto">PROTO</span>';
  m.innerHTML = `<div class="mh"><span class="name" style="color:${a.c}">${esc(a.e)} ${esc(a.n)}</span><span class="time">${time()}</span>${tags}</div><div class="body">${esc(txt)}</div>`;
  $('log').appendChild(m);
  $('log').scrollTop = $('log').scrollHeight;
  hist.push({id:a.id, n:a.n, t:txt, model:a.model||'local'});
  if (hist.length > 50) hist.shift();
  if (!user) addToMemory(`${a.n}: ${txt.slice(0,80)}`);
  save();
}
function sys(t, err=false, proto=false){
  const m = document.createElement('div');
  m.className = 'msg sys' + (err?' err':'') + (proto?' proto-sys':'');
  m.textContent = t;
  $('log').appendChild(m);
  $('log').scrollTop = $('log').scrollHeight;
}
function sysOracle(t){
  const m = document.createElement('div');
  m.className = 'msg sys oracle-sys';
  m.textContent = t;
  $('log').appendChild(m);
  $('log').scrollTop = $('log').scrollHeight;
}
function thinking(a){
  const m = document.createElement('div');
  m.className = 'think';
  m.id = 'tk' + a.id;
  m.innerHTML = `<b style="color:${a.c}">${a.e} ${a.n}</b> ${webllmEngine?'LLM-LOCAL':'calcul'} <span class="dots"><span>.</span><span>.</span><span>.</span></span>`;
  $('log').appendChild(m);
  $('log').scrollTop = $('log').scrollHeight;
}
function unthink(a){ const e = $('tk'+a.id); if(e) e.remove(); }

/* ════════════════════════════════════════════════════════════════════════
   PANNEAUX BBB & MODULES
   ════════════════════════════════════════════════════════════════════════ */
function toggleBBBPanel(){
  const p = $('bbbPanel');
  const open = p.style.display === 'block';
  p.style.display = open ? 'none' : 'block';
  if (!open) updateBBBDisplay();
}
function toggleModulesPanel(){
  const p = $('modulesPanel');
  const open = p.style.display === 'block';
  p.style.display = open ? 'none' : 'block';
  if (!open) renderModulesList();
}
function updateBBBDisplay(){
  $('bbbVer').textContent = BBB.version;
  $('bbbDrift').textContent = BBB.state.drift_score.toFixed(2);
  $('driftBadge').textContent = 'D ' + BBB.state.drift_score.toFixed(2);
  const db = $('driftBadge');
  db.classList.remove('warn','alert');
  if (BBB.state.drift_score < 0.6) db.classList.add('alert');
  else if (BBB.state.drift_score < 0.8) db.classList.add('warn');
  $('bbbRules').textContent = BBB.build_system_rules();
  const stats = BBB.classif_stats;
  const total = Object.values(stats).reduce((a,b)=>a+b, 0) || 1;
  $('bbbStats').innerHTML = Object.entries(stats).map(([k,v]) =>
    `<div>${k}: ${v} <span style="color:var(--mut)">(${Math.round(100*v/total)}%)</span></div>`
  ).join('');
}
function renderModulesList(){
  $('modulesList').innerHTML = MODULES.sort((a,b) => {
    const ord = {REAL:0, STUB:1, VISION:2};
    return ord[a.s] - ord[b.s];
  }).map(m => `
    <div class="module-item">
      <div class="mname">${esc(m.n)} <span style="color:var(--mut);font-size:8px">${esc(m.note)}</span></div>
      <div class="mstatus ${m.s.toLowerCase()}">${m.s}</div>
    </div>
  `).join('');
}

/* ════════════════════════════════════════════════════════════════════════
   TOGGLES
   ════════════════════════════════════════════════════════════════════════ */
function toggleAuto(){ auto = !auto; syncBtns(); loop(); save(); }
function cycleSpeed(){ sp = (sp+1) % SPEED.length; $('speed').textContent = SLAB[sp]; loop(); save(); }
function cycleHybrid(){ hybridMode = (hybridMode+1) % 3; syncBtns(); save(); sys('Mode : ' + HYBRID_LABELS[hybridMode]); }
function toggleGodMode(){
  godMode = !godMode;
  $('godbtn').classList.toggle('on', godMode);
  $('godbtn').textContent = godMode ? 'GOD: ON' : 'GOD';
  sys(godMode ? 'GOD MODE ON.' : 'GOD MODE OFF.');
  save();
}
function syncBtns(){
  $('auto').classList.toggle('on', auto);
  $('auto').textContent = auto ? 'AUTO' : 'PAUSE';
  $('hybrid').textContent = HYBRID_LABELS[hybridMode];
  $('hybrid').classList.toggle('on', hybridMode > 0);
  $('speed').textContent = SLAB[sp];
  $('modeBadge').textContent = webllmEngine ? 'LLM-LOCAL' : (hybridMode===0?'EDGE':hybridMode===1?'HYBRID':'NET+');
}
function clearAll(){
  $('log').innerHTML = ''; hist = []; turn = 0; MEMORY_CORE = [];
  Object.keys(usedConcepts).forEach(k => usedConcepts[k]?.clear());
  agentNarrative = {}; assocGraph = {};
  BBB.classif_stats = { FACT_VERIFIED:0, EMU_LOCAL:0, NETWORK_SYNTH:0, LOCAL_SYNTH:0, CACHE_HIT:0 };
  $('stat').textContent = 'ÉVEIL';
  sys('Canal nettoyé. Graphe + stats BBB réinitialisés. Cache oracles préservé.');
  save(); updateMemoryLog(); updateBBBDisplay();
}
function openCmd(){ $('cmd').style.display = 'block'; $('cmdin').focus(); }
function execCmd(){ const v = $('cmdin').value.trim(); $('cmdin').value = ''; $('cmd').style.display = 'none'; if (v) run(v); }
function loop(){ if (timer) clearInterval(timer); if (auto) timer = setInterval(() => { if (!busy) duel(); }, SPEED[sp] + 1400); }

/* ════════════════════════════════════════════════════════════════════════
   PERSISTANCE
   ════════════════════════════════════════════════════════════════════════ */
function save(){
  try {
    localStorage.setItem('omegaSovereignV71', JSON.stringify({
      spawned, nextId, hist, turn, auto, sp, hybridMode, scores,
      MEMORY_CORE, godMode, oracleCache, assocGraph, agentNarrative,
      bbb_drift: BBB.state.drift_score, bbb_stats: BBB.classif_stats,
      responseMode, ttsEnabled
    }));
  } catch(e) {}
}
function load(){
  try {
    const s = JSON.parse(localStorage.getItem('omegaSovereignV71') || '{}');
    spawned = s.spawned || []; nextId = s.nextId || 400;
    hist = s.hist || []; turn = s.turn || 0;
    auto = s.auto ?? true; sp = s.sp ?? 0;
    hybridMode = s.hybridMode ?? 1;
    scores = s.scores || {}; MEMORY_CORE = s.MEMORY_CORE || [];
    godMode = s.godMode ?? false;
    oracleCache = s.oracleCache || {};
    assocGraph = s.assocGraph || {};
    agentNarrative = s.agentNarrative || {};
    if (s.bbb_drift !== undefined) BBB.state.drift_score = s.bbb_drift;
    if (s.bbb_stats) BBB.classif_stats = s.bbb_stats;
    responseMode = s.responseMode ?? 0;
    ttsEnabled = s.ttsEnabled ?? false;
    syncBtns();
    if (godMode) { $('godbtn').classList.add('on'); $('godbtn').textContent = 'GOD: ON'; }
    if (ttsEnabled) $('ttsbtn').classList.add('on');
    $('modebtn').textContent = RESPONSE_MODES[responseMode];
    $('stat').textContent = turn ? turn + ' ÉCHANGES' : 'ÉVEIL';
  } catch(e) {}
}

/* ════════════════════════════════════════════════════════════════════════
   BACKGROUND MATRIX
   ════════════════════════════════════════════════════════════════════════ */
function bg(){
  const c = $('bg'), x = c.getContext('2d');
  let w, h, drops;
  function rz(){ w = c.width = innerWidth; h = c.height = innerHeight; drops = Array(Math.floor(w/14)).fill(1); }
  rz(); addEventListener('resize', rz);
  const chars = '01ΩΞΣ∞Λ⚛△✦⟁∑⊘∇Ψ◇⊕';
  function draw(){
    x.fillStyle = 'rgba(4,6,10,.18)'; x.fillRect(0,0,w,h);
    x.font = '15px JetBrains Mono';
    for (let i=0; i<drops.length; i++){
      const ch = chars[Math.floor(Math.random()*chars.length)];
      const r = Math.random();
      x.fillStyle = r > .97 ? '#b0ffee' : r > .94 ? '#ffaa44' : r > .85 ? '#88ddff' : r > .5 ? '#28d4ff' : '#22ff88';
      x.fillText(ch, i*14, drops[i]*14);
      if (drops[i]*14 > h && Math.random() > .97) drops[i] = 0;
      drops[i]++;
    }
    requestAnimationFrame(draw);
  }
  draw();
}

/* ════════════════════════════════════════════════════════════════════════
   BOOT
   ════════════════════════════════════════════════════════════════════════ */
function boot(){
  BBB.init();
  load();
  all().forEach(a => { if(!scores[a.id]) scores[a.id] = {t:0,r:0}; });
  side(); clock(); setInterval(clock,1000); bg();
  sys(`ΩSOVEREIGN V7.1 OMEGA TOTAL STACK · ${all().length} agents · BBB ${BBB.version} actif · Prototype : ${PROTOTYPE.n}`);
  sys(`40 modules étiquetés : 12 RÉEL · 16 STUB · 12 VISION. Bouton ⚙ 40MOD pour la liste honnête.`);
  if (!localStorage.getItem('pollinations_token')) {
    sys('ℹ Sans token Pollinations : 1 req/15s. Récupère un token gratuit sur auth.pollinations.ai puis /token KEY.');
  }
  if (!localStorage.getItem('proto_introduced')) {
    setTimeout(() => introducePrototype(), 1000);
    localStorage.setItem('proto_introduced','1');
  }
  renderOracleList();
  updateMemoryLog();
  updateBBBDisplay();
  loop();
}
function clock(){
  const now = Date.now();
  let suffix = '';
  if (cooldownUntil > now) {
    suffix = ` · ⏸ ${Math.ceil((cooldownUntil-now)/1000)}s`;
    $('clock').style.color = 'var(--red)';
  } else {
    const tok = localStorage.getItem('pollinations_token');
    suffix = webllmEngine ? ' · ⊕ LOCAL-LLM' : (tok ? ' · 🌱 SEED' : ' · ANON');
    $('clock').style.color = webllmEngine ? 'var(--oracle)' : (tok ? 'var(--green)' : 'var(--mut)');
  }
  $('clock').textContent = time() + suffix;
}

boot();
</script>
</body>
</html>
